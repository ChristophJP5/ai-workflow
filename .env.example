# AI Workflow Environment Variables
# Copy this file to .env and fill in your values
# This file should NOT be committed to git (already in .gitignore)

# ============================================================
# NVIDIA API (Recommended - OpenAI-compatible)
# Get your API key from: https://build.nvidia.com/
# ============================================================
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/mistralai/mistral-large-3-675b-instruct-2512
# Other models: nvidia/nv-llama-3, nvidia/mistralai/mixtral-8x7b-instruct-v01, etc.

# ============================================================
# Alternative: Ollama (Local LLMs)
# ============================================================
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# ============================================================
# Alternative: OpenAI (Direct)
# ============================================================
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4

# ============================================================
# Alternative: Anthropic
# ============================================================
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-3-sonnet-20240229

# ============================================================
# GitHub Integration (optional)
# ============================================================
# GITHUB_TOKEN=ghp_your_token_here
# GITHUB_REPO=owner/repo

# ============================================================
# Jira Integration (optional)
# ============================================================
# JIRA_SERVER=https://your-company.atlassian.net
# JIRA_TOKEN=your_jira_token
# JIRA_USER=your_email@example.com

# ============================================================
# Aider Configuration (optional)
# ============================================================
# AIDER_MODEL=claude-3-5-sonnet
# AIDER_API_KEY=your_key_here
